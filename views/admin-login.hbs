<!DOCTYPE html>
<html lang="en">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>Shorttpd — Admin Login</title>
    <script src="https://cdn.tailwindcss.com"></script>
    <script src="/js/sha256.js"></script>
  </head>
  <body class="min-h-screen bg-gray-50 flex flex-col font-sans">

    <!-- Header -->
    <header class="bg-gray-900 text-white shadow-md">
      <div class="max-w-6xl mx-auto px-4 py-3 flex items-center justify-between">
        <span class="text-lg font-semibold tracking-tight">Shorttpd Admin</span>
      </div>
    </header>

    <!-- Login card -->
    <main class="flex-1 flex items-center justify-center px-4">
      <div class="w-full max-w-sm bg-white rounded-xl border border-gray-200 shadow-sm p-8">
        <h2 class="text-xl font-semibold text-gray-800 mb-6 text-center">Admin Sign In</h2>

        {{#if error}}
        <div class="mb-4 px-3 py-2 rounded-md bg-red-50 border border-red-200 text-sm text-red-600">
          아이디 또는 비밀번호가 올바르지 않습니다.
        </div>
        {{/if}}

        <form
          id="admin-login-form"
          method="post"
          onsubmit="event.preventDefault(); submitAdminLogin();"
          class="space-y-4"
        >
          <input type="hidden" id="hashed-password" name="password" />

          <div>
            <label for="username" class="block text-sm font-medium text-gray-600 mb-1">Username</label>
            <input
              id="username"
              name="username"
              type="text"
              autocomplete="username"
              required
              class="w-full px-3 py-2 text-sm border border-gray-300 rounded-md focus:outline-none focus:ring-2 focus:ring-gray-900 focus:border-transparent transition"
              placeholder="Admin username"
            />
          </div>

          <div>
            <label for="pw-raw" class="block text-sm font-medium text-gray-600 mb-1">Password</label>
            <input
              id="pw-raw"
              type="password"
              autocomplete="current-password"
              required
              class="w-full px-3 py-2 text-sm border border-gray-300 rounded-md focus:outline-none focus:ring-2 focus:ring-gray-900 focus:border-transparent transition"
              placeholder="Password"
            />
          </div>

          <button
            type="submit"
            class="w-full px-4 py-2 text-sm bg-gray-900 text-white rounded-md hover:bg-gray-700 transition-colors"
          >
            Login
          </button>
        </form>
      </div>
    </main>

    <script>
      (function () {
        const params = new URLSearchParams(location.search);
        if (params.get('error')) {
          document.getElementById('username').value = '';
          document.getElementById('pw-raw').value = '';
        }
      })();

      function submitAdminLogin() {
        const username = document.getElementById('username').value;
        const pwRaw = document.getElementById('pw-raw').value;
        document.getElementById('hashed-password').value = sha256(pwRaw);
        document.getElementById('pw-raw').value = '';
        document.getElementById('admin-login-form').submit();
      }
    </script>

  </body>
</html>
