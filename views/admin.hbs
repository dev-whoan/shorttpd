<!DOCTYPE html>
<html lang="en">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>Shorttpd — Admin</title>
    <script src="https://cdn.tailwindcss.com"></script>
    <script src="/js/util.js"></script>
    <script src="/js/admin.js"></script>
    <script src="/js/sha256.js"></script>
  </head>
  <body class="min-h-screen bg-gray-50 font-sans">

    <!-- Header -->
    <header class="bg-gray-900 text-white shadow-md fixed top-0 inset-x-0 z-20">
      <div class="max-w-4xl mx-auto px-4 py-3 flex items-center justify-between">
        <span class="text-lg font-semibold tracking-tight">Shorttpd Admin</span>
        <div class="flex items-center gap-2">
          <button
            onclick="showAddUserDialog()"
            class="flex items-center gap-1.5 px-3 py-1.5 text-sm bg-white text-gray-900 rounded hover:bg-gray-200 transition-colors font-medium"
          >
            <svg xmlns="http://www.w3.org/2000/svg" class="w-4 h-4" fill="none" viewBox="0 0 24 24" stroke="currentColor">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 4v16m8-8H4" />
            </svg>
            Add User
          </button>
          <button
            onclick="logoutAdminPage()"
            class="px-3 py-1.5 text-sm border border-gray-600 rounded hover:bg-gray-700 transition-colors"
          >
            Logout
          </button>
        </div>
      </div>
    </header>

    <!-- Main -->
    <main class="max-w-4xl mx-auto px-4 pt-20 pb-10">
      <h2 class="text-xl font-semibold text-gray-800 mb-4">User List</h2>

      <div class="bg-white rounded-lg border border-gray-200 shadow-sm overflow-hidden">
        <!-- Table header -->
        <div class="grid grid-cols-12 gap-2 px-4 py-2.5 bg-gray-50 border-b border-gray-200 text-xs font-semibold text-gray-500 uppercase tracking-wide">
          <div class="col-span-3">Username</div>
          <div class="col-span-7">Permissions</div>
          <div class="col-span-2"></div>
        </div>

        <ul id="user-list-wrapper">
          {{#data.user_list}}
            <li
              class="grid grid-cols-12 gap-2 px-4 py-3 border-b border-gray-100 last:border-b-0 items-center hover:bg-gray-50"
              data-user="{{this.username}}"
              data-permission="{{this.permission}}"
            >
              <div class="col-span-3 font-medium text-gray-800 text-sm truncate">{{this.username}}</div>
              <div class="col-span-7 text-xs text-gray-500 font-mono truncate">{{this.permission}}</div>
              <div class="col-span-2 flex justify-end gap-1">
                <button
                  onclick="showEditUserDialog(this.closest('li').dataset.user, this.closest('li').dataset.permission)"
                  class="w-7 h-7 flex items-center justify-center rounded text-gray-400 hover:text-blue-500 hover:bg-blue-50 transition-colors"
                  title="Edit user"
                >
                  <svg xmlns="http://www.w3.org/2000/svg" class="w-3.5 h-3.5" fill="none" viewBox="0 0 24 24" stroke="currentColor">
                    <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M15.232 5.232l3.536 3.536M9 13l6.5-6.5a2 2 0 112.828 2.828L11.828 15.828A2 2 0 0111 16.414V19h2.586a2 2 0 001.414-.586l6.5-6.5" />
                  </svg>
                </button>
                <button
                  onclick="removeUser(this.closest('li'))"
                  class="w-7 h-7 flex items-center justify-center rounded text-gray-400 hover:text-red-500 hover:bg-red-50 transition-colors text-lg leading-none"
                  title="Remove user"
                >×</button>
              </div>
            </li>
          {{/data.user_list}}
        </ul>
      </div>
    </main>

    <!-- Add User Modal -->
    <div
      id="user-add-popup"
      class="hidden fixed inset-0 z-30 flex items-center justify-center bg-black/40 backdrop-blur-sm"
    >
      <div class="bg-white rounded-xl shadow-xl w-full max-w-md mx-4 p-6">
        <h3 class="text-lg font-semibold text-gray-800 mb-5">Add New User</h3>

        <div class="space-y-4">
          <div>
            <label for="id-value" class="block text-sm font-medium text-gray-600 mb-1">Username</label>
            <input
              id="id-value"
              type="text"
              autocomplete="off"
              class="w-full px-3 py-2 text-sm border border-gray-300 rounded-md focus:outline-none focus:ring-2 focus:ring-gray-900 focus:border-transparent transition"
              placeholder="Username"
            />
          </div>

          <div>
            <label for="pw-value" class="block text-sm font-medium text-gray-600 mb-1">Password</label>
            <input
              id="pw-value"
              type="password"
              autocomplete="new-password"
              class="w-full px-3 py-2 text-sm border border-gray-300 rounded-md focus:outline-none focus:ring-2 focus:ring-gray-900 focus:border-transparent transition"
              placeholder="Password"
            />
          </div>

          <div>
            <div class="flex items-center justify-between mb-2">
              <label class="block text-sm font-medium text-gray-600">Permissions</label>
              <button
                type="button"
                onclick="addPermissionRow(undefined, undefined, 'perm-list')"
                class="flex items-center gap-1 text-xs text-gray-500 hover:text-gray-800 transition-colors"
              >
                <svg xmlns="http://www.w3.org/2000/svg" class="w-3.5 h-3.5" fill="none" viewBox="0 0 24 24" stroke="currentColor">
                  <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 4v16m8-8H4" />
                </svg>
                Add row
              </button>
            </div>
            <div id="perm-list" class="space-y-2"></div>
            <div class="mt-2 space-y-0.5 text-xs text-gray-400">
              <p><span class="font-mono font-medium text-gray-500">r</span> — readonly</p>
              <p><span class="font-mono font-medium text-gray-500">rw</span> — read, write</p>
              <p><span class="font-mono font-medium text-gray-500">rwd</span> — read, write, delete</p>
            </div>
          </div>
        </div>

        <div class="flex gap-3 mt-6">
          <button
            type="button"
            onclick="closeAddUserDialog()"
            class="flex-1 px-4 py-2 text-sm border border-gray-300 rounded-md text-gray-600 hover:bg-gray-50 transition-colors"
          >
            Cancel
          </button>
          <button
            type="button"
            onclick="registerUser()"
            class="flex-1 px-4 py-2 text-sm bg-gray-900 text-white rounded-md hover:bg-gray-700 transition-colors"
          >
            Add User
          </button>
        </div>
      </div>
    </div>

    <!-- Edit User Modal -->
    <div
      id="user-edit-popup"
      class="hidden fixed inset-0 z-30 flex items-center justify-center bg-black/40 backdrop-blur-sm"
    >
      <div class="bg-white rounded-xl shadow-xl w-full max-w-md mx-4 p-6">
        <h3 class="text-lg font-semibold text-gray-800 mb-1">Edit User</h3>
        <p id="edit-username-label" class="text-sm text-gray-400 mb-5"></p>
        <input type="hidden" id="edit-username" />

        <div class="space-y-4">
          <div>
            <label for="edit-pw-value" class="block text-sm font-medium text-gray-600 mb-1">
              New Password
              <span class="text-gray-400 font-normal">(leave blank to keep current)</span>
            </label>
            <input
              id="edit-pw-value"
              type="password"
              autocomplete="new-password"
              class="w-full px-3 py-2 text-sm border border-gray-300 rounded-md focus:outline-none focus:ring-2 focus:ring-gray-900 focus:border-transparent transition"
              placeholder="New password"
            />
          </div>

          <div>
            <div class="flex items-center justify-between mb-2">
              <label class="block text-sm font-medium text-gray-600">Permissions</label>
              <button
                type="button"
                onclick="addPermissionRow(undefined, undefined, 'edit-perm-list')"
                class="flex items-center gap-1 text-xs text-gray-500 hover:text-gray-800 transition-colors"
              >
                <svg xmlns="http://www.w3.org/2000/svg" class="w-3.5 h-3.5" fill="none" viewBox="0 0 24 24" stroke="currentColor">
                  <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 4v16m8-8H4" />
                </svg>
                Add row
              </button>
            </div>
            <div id="edit-perm-list" class="space-y-2"></div>
            <div class="mt-2 space-y-0.5 text-xs text-gray-400">
              <p><span class="font-mono font-medium text-gray-500">r</span> — readonly</p>
              <p><span class="font-mono font-medium text-gray-500">rw</span> — read, write</p>
              <p><span class="font-mono font-medium text-gray-500">rwd</span> — read, write, delete</p>
            </div>
          </div>
        </div>

        <div class="flex gap-3 mt-6">
          <button
            type="button"
            onclick="closeEditUserDialog()"
            class="flex-1 px-4 py-2 text-sm border border-gray-300 rounded-md text-gray-600 hover:bg-gray-50 transition-colors"
          >
            Cancel
          </button>
          <button
            type="button"
            onclick="updateUser()"
            class="flex-1 px-4 py-2 text-sm bg-gray-900 text-white rounded-md hover:bg-gray-700 transition-colors"
          >
            Save
          </button>
        </div>
      </div>
    </div>

  </body>
</html>
