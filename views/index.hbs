<!DOCTYPE html>
<html lang="en">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>Shorttpd — File Server</title>
    <script src="https://cdn.tailwindcss.com"></script>
    <script src="/js/util.js"></script>
    <script src="/js/app.js"></script>
  </head>
  <body class="min-h-screen bg-gray-50 flex flex-col font-sans">

    <!-- Header -->
    <header class="bg-gray-900 text-white shadow-md">
      <div class="max-w-6xl mx-auto px-4 py-3 flex items-center justify-between">
        <button
          onclick="location.href = '/';"
          class="text-lg font-semibold tracking-tight hover:text-gray-300 transition-colors"
        >
          Shorttpd
        </button>
        {{#if logined}}
          <div class="flex items-center gap-2">
            <button
              onclick="location.href='/users/profile';"
              class="text-sm px-3 py-1.5 rounded border border-gray-600 hover:bg-gray-700 transition-colors"
            >
              Profile
            </button>
            <button
              onclick="logout()"
              class="text-sm px-3 py-1.5 rounded border border-gray-600 hover:bg-gray-700 transition-colors"
            >
              Logout
            </button>
          </div>
        {{/if}}
      </div>
    </header>

    <!-- Main -->
    <main class="flex-1 max-w-6xl mx-auto w-full px-4 py-6">

      <!-- Breadcrumb path -->
      <div class="mb-4 flex items-center gap-2 text-sm text-gray-500">
        <svg xmlns="http://www.w3.org/2000/svg" class="w-4 h-4 shrink-0" fill="none" viewBox="0 0 24 24" stroke="currentColor">
          <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M3 7h18M3 12h18M3 17h18" />
        </svg>
        <span id="current-location" class="font-mono text-gray-700 truncate">/</span>
      </div>

      <!-- Upload area -->
      {{#if canUpload}}
        <div class="mb-5 p-4 bg-white rounded-lg border border-dashed border-gray-300 flex flex-col gap-3">
          <!-- Upload row -->
          <div class="flex flex-col sm:flex-row sm:items-center gap-3">
            <label class="flex-1 flex items-center gap-2 cursor-pointer text-sm text-gray-600">
              <svg xmlns="http://www.w3.org/2000/svg" class="w-5 h-5 text-gray-400" fill="none" viewBox="0 0 24 24" stroke="currentColor">
                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M15.172 7l-6.586 6.586a2 2 0 102.828 2.828l6.414-6.586a4 4 0 00-5.656-5.656l-6.415 6.585a6 6 0 108.486 8.486L20.5 13" />
              </svg>
              <input type="file" id="upload-input" multiple class="hidden" onchange="updateUploadLabel(this)" />
              <span id="upload-label">Choose files to upload...</span>
            </label>
            <div class="flex flex-col gap-1.5 w-full sm:w-auto">
              <div class="flex items-center gap-2">
                <span id="upload-status" class="text-sm text-gray-500"></span>
                <button
                  type="button"
                  onclick="uploadFiles()"
                  class="px-4 py-1.5 bg-gray-900 text-white text-sm rounded hover:bg-gray-700 transition-colors"
                >
                  Upload
                </button>
              </div>
              <div id="upload-progress-wrap" class="hidden w-full sm:w-48 h-1.5 bg-gray-200 rounded-full overflow-hidden">
                <div id="upload-progress-bar" class="h-full bg-gray-900 transition-all duration-150" style="width:0%"></div>
              </div>
            </div>
          </div>
          <!-- Mkdir row -->
          <div class="flex items-center gap-2 border-t border-gray-100 pt-3">
            <svg xmlns="http://www.w3.org/2000/svg" class="w-4 h-4 text-gray-400 shrink-0" fill="none" viewBox="0 0 24 24" stroke="currentColor">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 13h6m-3-3v6m-9 1V7a2 2 0 012-2h6l2 2h6a2 2 0 012 2v8a2 2 0 01-2 2H5a2 2 0 01-2-2z" />
            </svg>
            <input
              type="text"
              id="mkdir-input"
              placeholder="New folder name"
              class="flex-1 px-2 py-1.5 text-sm border border-gray-300 rounded-md focus:outline-none focus:ring-1 focus:ring-gray-900"
            />
            <button
              type="button"
              onclick="mkdir()"
              class="px-4 py-1.5 bg-gray-900 text-white text-sm rounded hover:bg-gray-700 transition-colors"
            >
              Create Folder
            </button>
          </div>
        </div>
      {{/if}}

      <!-- File table -->
      <div class="bg-white rounded-lg border border-gray-200 overflow-hidden shadow-sm">
        <!-- Table header -->
        <div class="grid grid-cols-12 gap-2 px-4 py-2.5 bg-gray-50 border-b border-gray-200 text-xs font-semibold text-gray-500 uppercase tracking-wide">
          <div class="col-span-1"></div>
          <div class="col-span-6">Name</div>
          <div class="col-span-2 text-right">Size</div>
          <div class="col-span-2 text-right">Modified</div>
          <div class="col-span-1"></div>
        </div>

        <!-- Parent directory row -->
        <div
          class="file-row grid grid-cols-12 gap-2 px-4 py-3 border-b border-gray-100 hover:bg-gray-50 cursor-pointer transition-colors items-center"
        >
          <div class="col-span-1 flex justify-center">
            <img src="/img/dir.png" class="w-5 h-5 object-contain opacity-70" alt="dir" />
          </div>
          <div class="col-span-6 cursor-pointer">
            <span class="file-name text-blue-600 hover:underline text-sm font-medium">..</span>
          </div>
          <div class="col-span-2"></div>
          <div class="col-span-2"></div>
          <div class="col-span-1"></div>
        </div>

        {{#file_list}}
          <div
            class="file-row grid grid-cols-12 gap-2 px-4 py-3 border-b border-gray-100 last:border-b-0 hover:bg-gray-50 transition-colors items-center"
          >
            <div class="col-span-1 flex justify-center">
              {{#if this.dir}}
                <img src="/img/dir.png" class="w-5 h-5 object-contain opacity-70" alt="dir" />
              {{else}}
                <img src="/img/file.png" class="w-5 h-5 object-contain opacity-60" alt="file" />
              {{/if}}
            </div>
            <div class="col-span-6 min-w-0 cursor-pointer">
              <span class="file-name text-sm truncate block" data-isdir="{{this.dir}}">{{this.name}}</span>
            </div>
            <div class="col-span-2 text-right text-xs text-gray-400 font-mono">{{this.size}}</div>
            <div class="col-span-2 text-right text-xs text-gray-400">
              {{#if this.lastModified}}{{this.lastModified}}{{/if}}
            </div>
            <div class="col-span-1 flex justify-end">
              {{#if ../canDeleteDir}}
                {{#if this.dir}}
                  <button
                    onclick="rmdir('{{this.name}}')"
                    class="w-7 h-7 flex items-center justify-center rounded text-gray-300 hover:text-red-500 hover:bg-red-50 transition-colors text-lg leading-none"
                    title="Delete folder"
                  >×</button>
                {{/if}}
              {{/if}}
            </div>
          </div>
        {{/file_list}}
      </div>
    </main>

    <!-- Footer -->
    <footer class="border-t border-gray-200 bg-white mt-auto">
      <div class="max-w-6xl mx-auto px-4 py-3 flex items-center gap-2 text-xs text-gray-400">
        <a href="https://github.com/dev-whoan/shorttpd" target="_blank" class="hover:text-gray-600 transition-colors">
          <img src="/img/github.png" class="w-4 h-4 inline-block" alt="GitHub" />
        </a>
        <span>Developed by <a href="https://github.com/dev-whoan" class="hover:text-gray-600 underline">dev-whoan</a></span>
      </div>
    </footer>

  </body>
</html>
