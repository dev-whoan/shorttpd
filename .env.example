# ── Server ────────────────────────────────────────────────
# Port the server listens on (default: 5000)
PORT=5000

# Comma-separated list of allowed CORS origins
# Use * to allow all origins (not recommended in production)
CORS_ORIGIN_LIST=http://localhost:5050

# Runtime environment: set to "production" to disable dev features
NODE_ENV=development

# ── Authentication ─────────────────────────────────────────
# Enable JWT-based auth for file access ("yes" | "no")
USE_AUTH=yes

# Secret key used to sign and verify JWT tokens
# Required when USE_AUTH=yes
JWT_SECRET=change_me_to_a_long_random_secret

# ── Admin Page ────────────────────────────────────────────
# URL path for the admin panel (must not be "/")
ADMIN_PAGE_PREFIX=/admin

# Basic Auth credentials for the admin page
ADMIN_USERNAME=shorttpd
ADMIN_PASSWORD=shorttpd_password

# ── Upload ────────────────────────────────────────────────
# Maximum file size per upload in MB (default: 512)
UPLOAD_MAX_SIZE_MB=512

# ── File Serving ──────────────────────────────────────────
# Comma-separated file/directory names to hide from the web UI
# Example: .git,.env,node_modules
WEB_VIEW_EXCLUDE=.DS_Store,.git,.env,node_modules

# Comma-separated file extensions to open inline in the browser
# (instead of downloading). Example: pdf,txt,png,jpg
WEB_VIEW_EXTENSION=json,conf,ini,png,jpeg,jpg,gif,txt
